#!/usr/bin/env bash
set -euo pipefail

: "${CODE_SERVER_HOST:=0.0.0.0}"
: "${CODE_SERVER_PORT:=8080}"
: "${CODE_SERVER_AUTH:=none}"
: "${CODE_SERVER_WORKDIR:=/workspace}"

mkdir -p "${CODE_SERVER_WORKDIR}" /root/.config/code-server /root/.local/share/code-server

if [ "${START_CODE_SERVER:-1}" = "1" ]; then
  exec code-server \
    --bind-addr "${CODE_SERVER_HOST}:${CODE_SERVER_PORT}" \
    --auth "${CODE_SERVER_AUTH}" \
    "${CODE_SERVER_WORKDIR}"
fi

exec bash --login
