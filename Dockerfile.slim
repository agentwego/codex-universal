# syntax=docker/dockerfile:1.7
FROM ubuntu:26.04

ARG TARGETARCH
ARG GO_VERSION=1.26.3
ARG NODE_VERSION=24
ARG KUSTOMIZE_VERSION=5.8.1
ARG TALOSCTL_VERSION=1.13.3
ARG FLUX_VERSION=2.8.8
ARG SOPS_VERSION=3.13.1
ARG HELM_VERSION=4.2.0
ARG TASK_VERSION=3.51.1
ARG BUILDX_VERSION=0.34.1
ARG DOCKER_COMPOSE_VERSION=5.1.4
ARG ANSWER_SWAG_VERSION=1.16.3
ARG ANSWER_WIRE_VERSION=0.5.0
ARG ANSWER_MOCKGEN_VERSION=0.6.0
ARG ANSWER_GOLANGCI_LINT_VERSION=2.6.2
ARG HERMES_REPO_HTTPS=https://github.com/agentwego/hermes-agent.git
ARG HERMES_BRANCH=feat/mattermost-tool-trace
ARG HERMES_SOURCE_REV=ce7a690497489df121a66030e9b31f87719fd9bf
ARG CODE_SERVER_VERSION=

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PATH=/root/.local/bin:/root/go/bin:/usr/local/go/bin:/opt/node/bin:${PATH} \
    COREPACK_ENABLE_DOWNLOAD_PROMPT=0

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        wget \
        gnupg \
        sudo \
        bash-completion \
        build-essential \
        docker.io \
        pkg-config \
        git \
        git-lfs \
        openssh-client \
        python3 \
        python3-dev \
        libffi-dev \
        python3-pip \
        python3-venv \
        pipx \
        jq \
        yq \
        ripgrep \
        fd-find \
        fastfetch \
        unzip \
        zip \
        tar \
        gzip \
        xz-utils \
        less \
        vim-tiny \
        nano \
        make \
        gettext-base \
        rsync \
        netcat-openbsd \
        iputils-ping \
        dnsutils \
        openssl \
        age \
        tini \
    && git lfs install --system \
    && ln -sf /usr/bin/python3 /usr/local/bin/python \
    && ln -sf /usr/bin/python3 /usr/local/bin/python3 \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI and kubectl via official apt repositories.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    install -dm 0755 /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
    && curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.36/deb/Release.key | gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/kubernetes-apt-keyring.gpg \
    && echo 'deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.36/deb/ /' > /etc/apt/sources.list.d/kubernetes.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh kubectl \
    && rm -rf /var/lib/apt/lists/*

# Go.
RUN case "${TARGETARCH:-amd64}" in \
      amd64) go_arch=amd64 ;; \
      arm64) go_arch=arm64 ;; \
      *) echo "unsupported TARGETARCH=${TARGETARCH}" >&2; exit 1 ;; \
    esac \
    && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${go_arch}.tar.gz" -o /tmp/go.tgz \
    && rm -rf /usr/local/go \
    && tar -C /usr/local -xzf /tmp/go.tgz \
    && rm /tmp/go.tgz \
    && ln -sf /usr/local/go/bin/go /usr/local/bin/go \
    && ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt \
    && go version

# Go developer tools used by Answer and other Go/React projects.
RUN GOBIN=/usr/local/bin go install "github.com/swaggo/swag/cmd/swag@v${ANSWER_SWAG_VERSION}" \
    && GOBIN=/usr/local/bin go install "github.com/google/wire/cmd/wire@v${ANSWER_WIRE_VERSION}" \
    && GOBIN=/usr/local/bin go install "go.uber.org/mock/mockgen@v${ANSWER_MOCKGEN_VERSION}" \
    && curl -sSfL "https://raw.githubusercontent.com/golangci/golangci-lint/v${ANSWER_GOLANGCI_LINT_VERSION}/install.sh" | sh -s -- -b /usr/local/bin "v${ANSWER_GOLANGCI_LINT_VERSION}" \
    && rm -rf /root/.cache/go-build /root/go/pkg/mod \
    && mockgen -version \
    && swag -v \
    && wire flags >/tmp/wire-flags.txt \
    && golangci-lint version

# Node.js + TypeScript + pnpm through corepack.
RUN case "${TARGETARCH:-amd64}" in \
      amd64) node_arch=x64 ;; \
      arm64) node_arch=arm64 ;; \
      *) echo "unsupported TARGETARCH=${TARGETARCH}" >&2; exit 1 ;; \
    esac \
    && node_version="$(curl -fsSL https://nodejs.org/dist/latest-v${NODE_VERSION}.x/SHASUMS256.txt | awk '/linux-'"${node_arch}"'.tar.xz$/ {sub(/^node-v/, "", $2); sub(/-linux-.*/, "", $2); print $2; exit}')" \
    && test -n "${node_version}" \
    && curl -fsSL "https://nodejs.org/dist/v${node_version}/node-v${node_version}-linux-${node_arch}.tar.xz" -o /tmp/node.tar.xz \
    && mkdir -p /opt/node \
    && tar -C /opt/node --strip-components=1 -xJf /tmp/node.tar.xz \
    && rm /tmp/node.tar.xz \
    && corepack enable \
    && corepack prepare pnpm@latest --activate \
    && ln -sf /opt/node/bin/node /usr/local/bin/node \
    && ln -sf /opt/node/bin/npm /usr/local/bin/npm \
    && ln -sf /opt/node/bin/npx /usr/local/bin/npx \
    && ln -sf /opt/node/bin/corepack /usr/local/bin/corepack \
    && ln -sf /opt/node/bin/pnpm /usr/local/bin/pnpm \
    && ln -sf /opt/node/bin/pnpx /usr/local/bin/pnpx \
    && ln -sf /opt/node/bin/yarn /usr/local/bin/yarn \
    && ln -sf /opt/node/bin/yarnpkg /usr/local/bin/yarnpkg \
    && npm install -g typescript tsx @types/node \
    && node --version \
    && pnpm --version \
    && tsc --version

# Python tooling commonly needed in devcontainers. Symlink pipx-installed
# tools into /usr/local/bin because runtime deployments provide their own PATH.
RUN python3 -m pipx ensurepath \
    && pipx install uv \
    && pipx install ruff \
    && pipx install black \
    && pipx install poetry \
    && for tool in uv ruff black poetry; do ln -sf "/root/.local/bin/${tool}" "/usr/local/bin/${tool}"; done \
    && uv --version \
    && ruff --version \
    && black --version \
    && poetry --version

# Kubernetes/GitOps/Talos helpers not provided as Ubuntu packages.
RUN case "${TARGETARCH:-amd64}" in \
      amd64) bin_arch=amd64; task_arch=amd64; kustomize_arch=amd64; compose_arch=x86_64 ;; \
      arm64) bin_arch=arm64; task_arch=arm64; kustomize_arch=arm64; compose_arch=aarch64 ;; \
      *) echo "unsupported TARGETARCH=${TARGETARCH}" >&2; exit 1 ;; \
    esac \
    && curl_retry=(curl -fL --retry 5 --retry-all-errors --retry-delay 3 --connect-timeout 20) \
    && "${curl_retry[@]}" "https://get.helm.sh/helm-v${HELM_VERSION}-linux-${bin_arch}.tar.gz" -o /tmp/helm.tgz \
    && tar -C /tmp -xzf /tmp/helm.tgz \
    && install -m 0755 "/tmp/linux-${bin_arch}/helm" /usr/local/bin/helm \
    && rm -rf /tmp/helm.tgz "/tmp/linux-${bin_arch}" \
    && "${curl_retry[@]}" "https://github.com/kubernetes-sigs/kustomize/releases/download/kustomize%2Fv${KUSTOMIZE_VERSION}/kustomize_v${KUSTOMIZE_VERSION}_linux_${kustomize_arch}.tar.gz" -o /tmp/kustomize.tgz \
    && tar -C /usr/local/bin -xzf /tmp/kustomize.tgz kustomize \
    && rm /tmp/kustomize.tgz \
    && "${curl_retry[@]}" "https://github.com/siderolabs/talos/releases/download/v${TALOSCTL_VERSION}/talosctl-linux-${bin_arch}" -o /usr/local/bin/talosctl \
    && chmod +x /usr/local/bin/talosctl \
    && "${curl_retry[@]}" "https://github.com/fluxcd/flux2/releases/download/v${FLUX_VERSION}/flux_${FLUX_VERSION}_linux_${bin_arch}.tar.gz" -o /tmp/flux.tgz \
    && tar -C /usr/local/bin -xzf /tmp/flux.tgz flux \
    && rm /tmp/flux.tgz \
    && "${curl_retry[@]}" "https://github.com/getsops/sops/releases/download/v${SOPS_VERSION}/sops-v${SOPS_VERSION}.linux.${bin_arch}" -o /usr/local/bin/sops \
    && chmod +x /usr/local/bin/sops \
    && "${curl_retry[@]}" "https://github.com/go-task/task/releases/download/v${TASK_VERSION}/task_linux_${task_arch}.tar.gz" -o /tmp/task.tgz \
    && tar -C /usr/local/bin -xzf /tmp/task.tgz task \
    && rm /tmp/task.tgz \
    && install -d /usr/local/lib/docker/cli-plugins \
    && "${curl_retry[@]}" "https://github.com/docker/buildx/releases/download/v${BUILDX_VERSION}/buildx-v${BUILDX_VERSION}.linux-${bin_arch}" -o /usr/local/lib/docker/cli-plugins/docker-buildx \
    && chmod +x /usr/local/lib/docker/cli-plugins/docker-buildx \
    && "${curl_retry[@]}" "https://github.com/docker/compose/releases/download/v${DOCKER_COMPOSE_VERSION}/docker-compose-linux-${compose_arch}" -o /usr/local/lib/docker/cli-plugins/docker-compose \
    && chmod +x /usr/local/lib/docker/cli-plugins/docker-compose \
    && ln -sf /usr/local/lib/docker/cli-plugins/docker-compose /usr/local/bin/docker-compose \
    && helm version --short \
    && kustomize version \
    && talosctl version --client \
    && flux --version \
    && task --version \
    && docker buildx version


# code-server: standalone install under /usr/local to avoid systemd assumptions.
RUN curl_retry=(curl -fL --retry 5 --retry-all-errors --retry-delay 3 --connect-timeout 20) \
    && "${curl_retry[@]}" https://code-server.dev/install.sh -o /tmp/code-server-install.sh \
    && sh /tmp/code-server-install.sh --method standalone --prefix=/usr/local ${CODE_SERVER_VERSION:+--version ${CODE_SERVER_VERSION}} \
    && rm /tmp/code-server-install.sh \
    && code-server --version

# code-server font injection proxy.  It is baked into the image so runtime
# containers do not depend on host-local scripts or fonts.
COPY code-server-font-proxy/package*.json /usr/local/lib/code-server-font-proxy/
RUN npm ci --omit=dev --prefix /usr/local/lib/code-server-font-proxy \
    && npm cache clean --force
COPY code-server-font-proxy/ /usr/local/lib/code-server-font-proxy/

# Hermes Agent: root Docker install uses FHS layout at /usr/local/lib/hermes-agent
# and command wrappers in /usr/local/bin. Skip interactive setup and browser deps;
# runtime config/secrets are expected via mounted HERMES_HOME or env vars.
# Use the AgentWeGo fork branch directly instead of carrying file overlays.
RUN curl_retry=(curl -fL --retry 5 --retry-all-errors --retry-delay 3 --connect-timeout 20) \
    && "${curl_retry[@]}" https://raw.githubusercontent.com/NousResearch/hermes-agent/main/scripts/install.sh -o /tmp/hermes-install.sh \
    && sed -i \
        -e "s|^REPO_URL_SSH=.*|REPO_URL_SSH=\"${HERMES_REPO_HTTPS}\"|" \
        -e "s|^REPO_URL_HTTPS=.*|REPO_URL_HTTPS=\"${HERMES_REPO_HTTPS}\"|" \
        /tmp/hermes-install.sh \
    && bash /tmp/hermes-install.sh --branch "${HERMES_BRANCH}" --skip-setup --skip-browser \
    && rm /tmp/hermes-install.sh \
    && git -C /usr/local/lib/hermes-agent fetch origin "${HERMES_SOURCE_REV}" \
    && git -C /usr/local/lib/hermes-agent checkout --detach "${HERMES_SOURCE_REV}" \
    && hermes --version \
    && test "$(git -C /usr/local/lib/hermes-agent remote get-url origin)" = "${HERMES_REPO_HTTPS}" \
    && test "$(git -C /usr/local/lib/hermes-agent rev-parse HEAD)" = "${HERMES_SOURCE_REV}" \
    && python3 -m py_compile \
        /usr/local/lib/hermes-agent/gateway/run.py \
        /usr/local/lib/hermes-agent/gateway/tool_trace.py \
        /usr/local/lib/hermes-agent/agent/tool_executor.py \
    && hermes tools list >/tmp/hermes-tools-list.txt || true

COPY setup_slim.sh /opt/codex/setup_universal.sh
COPY verify_slim.sh /opt/codex/verify.sh
COPY devcontainer-start /usr/local/bin/devcontainer-start
RUN chmod +x /opt/codex/setup_universal.sh /opt/codex/verify.sh /usr/local/bin/devcontainer-start

WORKDIR /workspace
EXPOSE 8080
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/usr/local/bin/devcontainer-start"]
